#: import Factory kivy.factory.Factory
#: import Keypad rcp.components.popups.keypad

<CoordBar>:
  orientation: "horizontal"
  size_hint_y: 1
  Button:
    width: 96
    size_hint_x: None
    text: root.axis.axis_name if root.axis else "?"
    font_size: min(self.height / 1.5, self.width/1.5)
    background_color: [0.2, 1, 0.2, 1] if (root.axis and root.axis.syncEnable) else [0.3, 0.3, 0.3, 1]
    on_release: root.toggle_sync()

  BoxLayout:
    orientation: "horizontal"
    BoxLayout:
      size_hint_x: 0.5
      orientation: "vertical"
      Button:
        background_color: (0, 0, 0, 1)
        id: pos_label
        size_hint_y: 0.7
        font_name: app.formats.font_name
        font_size: min(self.height / 1.1, self.width/5)
        font_style: "bold"
        color: app.formats.display_color
        text: root.axis.formattedPosition if root.axis else "--"
        text_size: self.size
        halign: 'right'
        valign: 'center'
        on_release: root.update_position()
      Label:
        size_hint_y: 0.3
        font_name: app.formats.font_name
        font_size: self.height / 1.5
        font_style: "bold"
        color: app.formats.display_color
        text: root.axis.formattedSpeed if root.axis else "--"
        text_size: self.size
        halign: 'right'
        valign: 'top'

    BoxLayout:
      size_hint_x: None
      width: 80
      orientation: 'vertical'
      Label:
        text: "Num"
        font_size: self.height / 1.5
        size_hint_y: 0.3
        color: app.formats.display_color
        halign: 'center'
        valign: 'top'
      Button:
        size_hint_y: 0.7
        font_name: app.formats.font_name
        font_size: self.width / 3
        font_style: "bold"
        background_color: [0.3, 0.3, 0.3, 1]
        color: app.formats.display_color
        text: str(int(root.axis.syncRatioNum)) if root.axis else "--"
        text_size: self.size
        halign: 'center'
        valign: 'middle'
        on_release: Factory.Keypad(integer=True).show(root.axis, 'syncRatioNum') if root.axis else None

    BoxLayout:
      size_hint_x: None
      width: 80
      orientation: 'vertical'
      Label:
        text: "Den"
        font_size: self.height / 1.5
        size_hint_y: 0.3
        color: app.formats.display_color
        halign: 'center'
        valign: 'top'
      Button:
        size_hint_y: 0.7
        font_name: app.formats.font_name
        font_size: self.width / 3
        font_style: "bold"
        background_color: [0.3, 0.3, 0.3, 1]
        color: app.formats.display_color
        text: str(int(root.axis.syncRatioDen)) if root.axis else "--"
        text_size: self.size
        halign: 'center'
        valign: 'middle'
        on_release: Factory.Keypad(integer=True).show(root.axis, 'syncRatioDen') if root.axis else None

  Button:
    text: "Zero"
    font_size: 24
    font_style: "bold"
    background_color: [0.5, 0.5, 0.5, 1]
    width: self.height
    size_hint_x: None
    on_press: root.on_zero_press()
    on_release: root.on_zero_release()
