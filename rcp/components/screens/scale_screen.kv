#: import NumberItem rcp.components.widgets.number_item
#: import DualNumberItem rcp.components.widgets.dual_number_item

<ScaleScreen>:
  BoxLayout:
    orientation: "vertical"
    padding: 10
    ScreenHeader:
      text: "Scale Input {}".format(root.scale.inputIndex)

    ScrollView:
      do_scroll_x: False
      do_scroll_y: True
      GridLayout:
        id: grid_layout
        cols: 1
        spacing: 1
        size_hint_y: None
        height: self.minimum_height

        NumberItem:
          name: "Ratio Numerator"
          value: root.scale.ratioNum
          integer: True
          on_value: root.scale.ratioNum = int(self.value)
        NumberItem:
          name: "Ratio Denominator"
          value: root.scale.ratioDen
          integer: True
          help_file: "scales.rst"
          on_value: root.scale.ratioDen = int(self.value)
