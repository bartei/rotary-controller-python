<LogsPanel>:
  orientation: "vertical"

  BoxLayout:
    orientation: "horizontal"
    size_hint_y: None
    height: 48
    Label:
      text: "Select a log file"
      font_size: 16
      text_size: self.size
      halign: "left"
      valign: "middle"
    Button:
      size_hint_x: None
      width: 200
      text: "Refresh"
      font_size: app.formats.font_size
      on_press: app.beep()
      on_release: root.refresh_logs()

  ScrollView:
    do_scroll_x: False
    do_scroll_y: True
    BoxLayout:
      id: file_list
      orientation: "vertical"
      size_hint_y: None
      height: self.minimum_height
      spacing: 4
      padding: 10