<LogsPanel>:
  orientation: "vertical"
  BoxLayout:
    orientation: "horizontal"
    size_hint_y: None
    height: 48
    Label:
      text: root.log_file_path
      font_size: 16
      text_size: self.size
      halign: "left"
      valign: "middle"
      shorten: True
    Button:
      size_hint_x: None
      width: 200
      text: "Refresh"
      font_size: 22
      on_release: root.refresh_logs()

  ScrollView:
    do_scroll_x: False
    do_scroll_y: True
    Label:
      text: root.log_content
      size_hint_y: None
      height: self.texture_size[1]
      text_size: self.width, None
      padding: 10, 10
      font_size: 14
      halign: "left"
      valign: "top"