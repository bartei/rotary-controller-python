<LogsPanel>:
  orientation: "vertical"

  BoxLayout:
    id: header
    orientation: "horizontal"
    size_hint_y: None
    height: 48
    Label:
      id: header_label
      text: "Select a log file"
      font_size: 16
      text_size: self.size
      halign: "left"
      valign: "middle"
      shorten: True
    Button:
      id: action_button
      size_hint_x: None
      width: 200
      text: "Refresh"
      font_size: app.formats.font_size
      on_release: root.on_action_button()