<ProfilingPanel>:
  orientation: "vertical"
  spacing: 5

  # FPS Stats Row
  BoxLayout:
    size_hint_y: None
    height: 48
    spacing: 10
    Label:
      text: f"FPS: {root.fps_current:.1f}"
      font_size: 20
      bold: True
      color: (0, 1, 0, 1) if root.fps_current > 25 else ((1, 1, 0, 1) if root.fps_current > 10 else (1, 0, 0, 1))
    Label:
      text: f"Min: {root.fps_min:.1f}"
      font_size: 18
    Label:
      text: f"Max: {root.fps_max:.1f}"
      font_size: 18
    Label:
      text: f"Avg: {root.fps_avg:.1f}"
      font_size: 18

  # Frame time row
  BoxLayout:
    size_hint_y: None
    height: 48
    spacing: 10
    Label:
      text: f"Frame: {root.frame_time_ms:.1f}ms"
      font_size: 18
    Label:
      text: f"Max frame: {root.frame_time_max_ms:.1f}ms"
      font_size: 18
      color: (1, 0, 0, 1) if root.frame_time_max_ms > 50 else (1, 1, 1, 1)
    Label:
      text: ""
    Label:
      text: ""

  # Controls row
  BoxLayout:
    size_hint_y: None
    height: 60
    spacing: 10
    padding: 0, 5
    Button:
      text: "Stop Profiling" if root.is_profiling else "Start Profiling"
      font_size: 22
      background_color: (0.8, 0.2, 0.2, 1) if root.is_profiling else (0.2, 0.6, 0.2, 1)
      on_press: app.beep()
      on_release: root.toggle_profiling()
    Button:
      text: "Reset Stats"
      font_size: 22
      on_press: app.beep()
      on_release: root.reset_stats()

  # Status
  Label:
    text: root.status_text
    size_hint_y: None
    height: 30
    font_size: 16
    halign: "left"
    text_size: self.size
    valign: "middle"

  # Profile results
  ScrollView:
    do_scroll_x: True
    do_scroll_y: True
    Label:
      text: root.profile_results
      size_hint: None, None
      width: max(self.texture_size[0] + 20, self.parent.width) if self.parent else self.texture_size[0] + 20
      height: self.texture_size[1] + 20
      text_size: None, None
      padding: 10, 10
      font_size: 13
      font_name: "fonts/iosevka-regular.ttf"
      halign: "left"
      valign: "top"